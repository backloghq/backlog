{
  "name": "backlog",
  "version": "1.0.5",
  "description": "Persistent, cross-session task management for Claude Code. Tasks survive sessions so work started by one agent can be picked up by another.",
  "author": {
    "name": "BacklogHQ"
  },
  "homepage": "https://backloghq.io",
  "repository": "https://github.com/backloghq/backlog",
  "license": "MIT",
  "keywords": ["tasks", "planning", "backlog", "persistence", "agent-teams"],
  "skills": "./skills/",
  "agents": ["./agents/task-planner.md"],
  "mcpServers": {
    "tasks": {
      "command": "${CLAUDE_PLUGIN_ROOT}/scripts/start-server.sh",
      "env": {
        "TASKDATA_ROOT": "${CLAUDE_PLUGIN_DATA}/projects"
      }
    }
  }
}
